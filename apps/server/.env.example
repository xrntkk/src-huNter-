# LLM Provider (required - pick one)
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Model to use (optional, defaults to claude-sonnet-4-5)
# ANTHROPIC_MODEL=claude-sonnet-4-5

# Database path (optional)
# DATABASE_URL=./data/src-agent.db

# Server port (optional, default 3001)
# PORT=3001

# Frontend origin for CORS (optional)
# WEB_ORIGIN=http://localhost:5173

# Firecrawl MCP（推荐在设置页 MCP 服务中配置，无需在此设置）
# 见：设置 → MCP 服务 → Firecrawl 一键添加

# Langfuse observability (optional — leave both keys blank to disable)
# Self-host: docker compose up at https://github.com/langfuse/langfuse
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=http://localhost:3000
